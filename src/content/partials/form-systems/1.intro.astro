---
import FeatureCard from '@/components/FeatureCard.astro'
import { Heading, Markdown } from '@splendidlabz/astro'
import { modules } from '../../data/courses/practical-astro.js'
const systemCard = modules.find(module => module.title === 'Form Systems')
---

<section class="section">
  <div class="wrap">
    <div class="vertical">
      <div class="grid-simple [--cols:5] max-w-[75rem] mx-auto items-center">
        <div class="vertical [--span:3]">
          <Heading class="gap-4" eyebrow="">
            <span class="eyebrow horizontal items-center gap-[0.125em]">
              Forms don't have to be hard
            </span>
            <h1 class="max-w-[8em]">Form handling Done Right</h1>
          </Heading>

          <div class="prose-responsive max-w-narrow">
            <!-- prettier-ignore -->
            <Markdown>
              Create SSR forms and API routes with patterns that stay readable even for complex forms  --- no tangled try/catch, no CAPTCHA, no need to manual sanitizing anything. 
              
              Spam blocking, input cleaning, array fields,
              multiple forms per page, and redirect-after-submit all just
              work, with clear error messages when they don't.
            </Markdown>

            <div class="vertical gap-2.5 self-start">
              <a
                href="#pricing"
                class="button button-large pigment-cyan-filled"
              >
                <Markdown inline>Get Form Systems --- $49</Markdown>
              </a>
              <p class="text-8 text-zgray-500 text-center italic">
                <Markdown inline>
                  Pay once. Lifetime access. Free updates forever.
                </Markdown>
              </p>
            </div>
          </div>
        </div>
        <div class="[--span:2]">
          <FeatureCard
            class="opacity-80"
            readyByPosition="edge-topright-start"
            {...systemCard}
            showButton={false}
            showPrice={false}
          />
        </div>
      </div>
    </div>
  </div>
</section>
