---
import FeatureCard from '@/components/FeatureCard.astro'
import { Heading, Markdown } from '@splendidlabz/astro'
import { modules } from '../../data/courses/practical-astro.js'
const imageSystems = modules.find(module => module.title === 'Image Systems')
---

<section class="section">
  <div class="wrap">
    <div class="vertical">
      <div class="grid-simple [--cols:5] max-w-[75rem] mx-auto items-center">
        <div class="vertical [--span:3]">
          <Heading class="gap-4" eyebrow="">
            <span class="eyebrow horizontal items-center gap-[0.125em]">
              Image optimization for Astro
            </span>
            <h1 class="max-w-[10em]">
              The Image System I Reach For on Every Astro Site
            </h1>
          </Heading>

          <div class="prose-responsive max-w-narrow">
            <!-- prettier-ignore -->
            <Markdown>
              Responsive images, art direction, background images, SVGs, icons, videos, and GIF replacements. Drop them into your pages and never think about image optimization again.
            </Markdown>

            <div class="vertical gap-2.5 self-start">
              <a
                href="#pricing"
                class="button button-large pigment-cyan-filled"
              >
                <Markdown inline>Get Image Systems --- $49</Markdown>
              </a>
              <p class="text-8 text-zgray-500 text-center italic">
                <Markdown inline>
                  Pay once. Lifetime access. Free updates forever.
                </Markdown>
              </p>
            </div>
          </div>
        </div>
        <div class="[--span:2]">
          <FeatureCard
            class="opacity-80"
            readyByPosition="edge-topright-start"
            {...imageSystems}
            showButton={false}
            showPrice={false}
          />
        </div>
      </div>
    </div>
  </div>
</section>
