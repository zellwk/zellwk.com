---
import OneColumn from '@/layouts/OneColumn.astro'
import { makeEmail, sendEmail } from '@/services/email'
import { Sheets } from '@/services/google-sheets'
import { Markdown } from '@splendidlabz/astro'
import { getSearchParams, parseData } from '@splendidlabz/astro/server'
import { Form, Textarea, TextInput } from '@splendidlabz/svelte'
import { toTitle } from '@splendidlabz/utils'
import { format } from 'date-fns'

export const prerender = false

const params = getSearchParams(Astro)

// ThriveCart passes these as bracket-keyed params. camelCaseKeys leaves the
// brackets untouched, so they come through getSearchParams unchanged.
const name = params['thrivecart[customer][name]'] || ''
const email = params['thrivecart[customer][email]'] || ''
const product = params['thrivecart[order][0][n]'] || ''
const pdt = params.product && toTitle(params.product)

const productName = product || pdt
const redirectURL = '/courses/welcome/' + Astro.url.searchParams.toString()

// See Google Sheet here:
// https://docs.google.com/spreadsheets/u/1/d/12NpFSAhbtZB71RxAq4RxUUeCO7lGgMMA7e2l_MVsNzU/edit?gid=0#gid=0
const SHEET_ID = '12NpFSAhbtZB71RxAq4RxUUeCO7lGgMMA7e2l_MVsNzU'

const props = {
  ...Astro.props,
  title: `Thanks for grabbing ${productName}!`,
  titleWidth: '11em',
}

let values = {
  name,
  email,
  why: '',
  hope: '',
  better: '',
  success: '',
}
const errors: Record<string, string> = {}

POST: if (Astro.request.method === 'POST') {
  const body = await parseData(Astro)
  const { name, email, phone, why, hope, better, success } = body
  values = { name, email, why, hope, better, success }

  if (phone) break POST

  if (!name) errors.name = 'Please enter your name'
  if (!email) errors.email = 'Please enter your email'

  if (Object.keys(errors).length > 0) break POST

  // SEND SURVEY DATA TO THE EXCEL.
  // Automatically silence errors.
  try {
    console.log('Sending Sheet')
    await Sheets.appendOne(SHEET_ID, {
      value: [
        format(Date.now(), 'yyyy-MM-dd'),
        name,
        email,
        productName,
        why,
        hope,
        better,
        success,
        import.meta.env.DEV && 'From Dev',
      ],
    })
  } catch (e) {
    console.log(e)
  }

  // EMAIL IT TO ME
  if (import.meta.env.PROD) {
    const emailProps = {
      to: 'zell@zellwk.com',
      template: 'Survey',
      data: {
        subject: `${productName} Welcome Survey`,
        name,
        email,
        why,
        hope,
        better,
        success,
      },
    }

    const { html, text } = await makeEmail(emailProps.template, emailProps.data)

    await sendEmail({
      to: emailProps.to,
      subject: emailProps.data.subject,
      html,
      text,
    })
  }

  // Proceeds to the next step of the purchase flow.
  return Astro.redirect(redirectURL)
}
---

<OneColumn {...props}>
  <!-- prettier-ignore -->
  <Markdown>
    One thing before you dive in. 
    
    **The people who get the most out of this are the ones who know what they're aiming at** --- so take two minutes on the questions below to get clear on what you came here for. Rough answers are fine. 
    
    And I read every one. They tell me what to build next and what to point you to first.
  </Markdown>

  <Form method="POST" class="vertical gap-6" honeypotName="phone">
    <div class="grid-simple [--cols:2] items-end">
      <TextInput
        name="name"
        label="Your Name"
        value={values.name}
        error={errors.name}
      />
      <TextInput
        name="email"
        label="Email"
        value={values.email}
        error={errors.email}
      />
    </div>

    <Textarea
      name="why"
      label=`What finally made you buy ${productName}?`
      hint="Is there a specific project that pushed you, or a frustration you
  kept running into?"
      value={values.why}
    />
    <Textarea
      name="hope"
      label=`What are you hoping to build or pull off?`
      hint="Specific sites, features, or skill gaps you want to close — and what'd make you glad you bought this six months from now?"
      value={values.hope}
    />
    <Textarea
      name="better"
      label=`Is there anything specific you're hoping we cover?`
      hint="Anything you've searched for over and over but never found a straight answer eleswhere?"
      value={values.better}
    />

    <button class="button landing-button pigment-purple-filled">
      Continue
    </button>
  </Form>
</OneColumn>
