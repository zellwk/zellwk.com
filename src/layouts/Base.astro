---
import MainNav from '../components/MainNav.svelte'
import Footer from '../components/Footer.astro'
import '../styles/styles.css'
import Head from './Base/Head.astro'
const { class: bodyClass, ...props } = Astro.props
---

<html lang="en" class="scrollbars-on">
  <head>
    <Head {...props} />
  </head>

  <body class={`${bodyClass}  `}>
    <div class="shell-simple">
      <header><MainNav client:idle /></header>
      <main class="content my-16"><slot /></main>
      <Footer />
    </div>

    <script>
      import { fb, ph } from '@/services/tracking/web'

      fb.init()
      fb.track('PageView')
      ph.init()

      // Identify the buyer when a page renders the #ph-identify marker (e.g. the
      // post-checkout survey). Runs after ph.init() so the merge actually lands.
      const idEl = document.getElementById('ph-identify')
      if (idEl?.dataset.email) {
        ph.identify(idEl.dataset.email, { name: idEl.dataset.name })
      }
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FF5QLS3KNY"
    ></script>
    <script async>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        window.dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', 'G-FF5QLS3KNY')
    </script>
  </body>
</html>
