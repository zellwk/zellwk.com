---
import { Markdown } from '@splendidlabz/astro'
import { notEmpty } from '@splendidlabz/utils'
import Base from './Base.astro'

const props = getProps(Astro)
const { title, titleWidth = '' } = props

function getProps(Astro) {
  if (notEmpty(Astro.props.content)) return Astro.props.content
  return Astro.props
}
---

<Base {...props}>
  <div class="wrap">
    <article class="article max-w-standard mx-auto">
      <div class="vertical">
        <header>
          <h1
            class="h1 text-center mx-auto"
            style={titleWidth && { maxWidth: titleWidth }}
          >
            <Markdown inline>{title} </Markdown>
          </h1>
        </header>
        <div id="content" class="prose-responsive !max-w-narrow mx-auto">
          <slot />
        </div>
      </div>
    </article>
  </div>
</Base>
